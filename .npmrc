@hrtbrxkxr:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
minimum-release-age=0
# หมายเหตุเรื่อง .npmrc: ผมสร้าง .npmrc ที่ project root กับ minimum-release-age=0 เพื่อให้ local dev ไม่ติด policy gate ของ pnpm 11 ใน environment นี้ ถ้าอยากให้เคร่งครัดเหมือนเดิม ลบได้ แต่ตอนนี้มัน block การ run script ใน sandbox ผมเลย set ไว้
