{
  "name": "@platform/shared-ui",
  "version": "1.0.0",
  "description": "Shared UI component library for the White Label Platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src/styles"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./theme.css": {
      "default": "./src/styles/theme.css"
    },
    "./styles.css": {
      "default": "./dist/shared-ui.css"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && pnpm build:css",
    "build:css": "tailwindcss -i src/styles/storybook.css -o dist/shared-ui.css --minify",
    "dev": "concurrently \"tsc -p tsconfig.build.json --watch --preserveWatchOutput\" \"tailwindcss -i src/styles/storybook.css -o dist/shared-ui.css --watch\"",
    "prepack": "pnpm build",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@storybook/react": "^10.4.6",
    "@types/react": "^19.2.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "concurrently": "^10.0.3",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.16"
  }
}
